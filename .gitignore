# OS / editor
.DS_Store
Thumbs.db

# Dependencies (the Laravel bootstrap change extends this file — merge, never replace)
/vendor/
/node_modules/

# Environment & secrets
.env
.env.*
!.env.example

# Claude Code local settings
.claude/settings.local.json

# Ralph runtime state (failure-context files live inside change dirs)
**/.last-output
.ralph/

# Transient reports
lint-report.md

# Laravel runtime (pre-seeded; framework defaults merged at bootstrap)
/storage/*.key
/public/build
/public/hot
/public/storage

# Laravel skeleton defaults (merged from laravel/laravel 13.x at bootstrap — union with the rules above)
*.log
.phpactor.json
.phpunit.result.cache
/.codex
/.cursor/
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
/public/fonts-manifest.dev.json
/storage/pail
_ide_helper.php
Homestead.json
Homestead.yaml
